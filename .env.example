# Antigravity Trading Engine Environment Variables

# 1. Exchange API Keys (Binance)
# WARNING: NEVER enable "Withdawals" on these keys!
BINANCE_API_KEY=your_public_api_key_here
BINANCE_API_SECRET=your_private_api_secret_here

# 2. Database & Data Warehouse
DATABASE_URL=postgres://antigravity:password123@localhost:5432/antigravity
REDIS_URL=redis://localhost:6379

# 3. AI Service Configuration
AI_GRPC_HOST=localhost:50051

# 4. AI Agent Keys (Multi-Model Council)
# Bull + Bear agents use gpt-4o-mini; Risk arbitration uses gpt-4o
OPENAI_API_KEY=sk-...
# Macro Analyst agent — Gemini Flash 2.0 top-down market view (optional but recommended)
GEMINI_API_KEY=AIza...

# 5. Engine Parameters
MAX_POSITION_BTC=0.5
MAX_DAILY_LOSS_PCT=0.10
